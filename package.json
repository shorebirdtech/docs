    "tailwindcss": "^4.2.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^4.0.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
