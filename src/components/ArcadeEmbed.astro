---
interface Props {
  src: string;
  title: string;
}

const { src, title } = Astro.props;
---

<div class="arcade-embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allowfullscreen
    allow="clipboard-write"
  ></iframe>
</div>

<style>
  .arcade-embed {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: calc(56.25% + 41px);
  }

  .arcade-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    color-scheme: light;
  }
</style>
